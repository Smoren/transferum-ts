{
  "compilerOptions": {
    "target": "ES6",
    "module": "Node16",
    "lib": ["es2017", "dom"],
    "rootDir": "./src",
    "allowJs": false,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "sourceMap": true,
    "inlineSources": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedModules": true
  },
  "exclude": ["tests"]
}
